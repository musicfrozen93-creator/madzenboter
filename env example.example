# ZenGrid Multi-Account Trading Platform — Environment Variables
# Copy this file to .env and fill in your values.

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# Database connection (used by the application)
DATABASE_URL=postgresql://zengrid:change_me_strong_password@localhost:5432/zengrid

# Master Binance API credentials (used if no accounts are configured)
BINANCE_API_KEY=your_master_api_key
BINANCE_API_SECRET=your_master_api_secret

# Fernet encryption key for client API keys
# Generate with: python scripts/generate_encryption_key.py
MASTER_ENCRYPTION_KEY=

# Admin API authentication
ADMIN_API_KEY=your_admin_api_key
ADMIN_API_PORT=8000
